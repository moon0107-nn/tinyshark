@model TinyShark.Models.Transaction

@{
    ViewData["Title"] = "Delete";
}

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:18px">
    <div>
        <h2 style="font-size:18px;font-weight:700;color:var(--ts-text);margin:0">Xoá giao dịch</h2>
        <p style="font-size:12.5px;color:var(--ts-text-muted);margin-top:4px">Hành động này không thể hoàn tác</p>
    </div>
    <a asp-action="Index" class="ts-btn ts-btn-outline">
        <i class="fa-solid fa-arrow-left"></i> Quay lại danh sách
    </a>
</div>

<div class="ts-panel" style="max-width:440px">
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:18px;padding:12px 14px;background:#FEE9E9;border-radius:8px">
        <i class="fa-solid fa-triangle-exclamation" style="color:#A83232;font-size:16px"></i>
        <span style="font-size:12.5px;color:#A83232;font-weight:500">Bạn có chắc muốn xoá giao dịch này không?</span>
    </div>

    <table style="width:100%;font-size:13px;margin-bottom:20px">
        <tr>
            <td style="color:var(--ts-text-muted);padding:8px 0;border-bottom:1px solid var(--ts-border)">
                @Html.DisplayNameFor(model => model.Amount)
            </td>
            <td style="text-align:right;padding:8px 0;border-bottom:1px solid var(--ts-border);font-weight:600">
                @Html.DisplayFor(model => model.Amount)₫
            </td>
        </tr>
        <tr>
            <td style="color:var(--ts-text-muted);padding:8px 0;border-bottom:1px solid var(--ts-border)">
                @Html.DisplayNameFor(model => model.Description)
            </td>
            <td style="text-align:right;padding:8px 0;border-bottom:1px solid var(--ts-border)">
                @Html.DisplayFor(model => model.Description)
            </td>
        </tr>
        <tr>
            <td style="color:var(--ts-text-muted);padding:8px 0;border-bottom:1px solid var(--ts-border)">
                @Html.DisplayNameFor(model => model.Date)
            </td>
            <td style="text-align:right;padding:8px 0;border-bottom:1px solid var(--ts-border)">
                @Html.DisplayFor(model => model.Date)
            </td>
        </tr>
        <tr>
            <td style="color:var(--ts-text-muted);padding:8px 0">
                @Html.DisplayNameFor(model => model.Type)
            </td>
            <td style="text-align:right;padding:8px 0">
                @Html.DisplayFor(model => model.Type)
            </td>
        </tr>
    </table>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <div style="display:flex;gap:8px">
            <input type="submit" value="Xác nhận xoá" class="ts-btn ts-btn-danger" style="cursor:pointer;border:none" />
            <a asp-action="Index" class="ts-btn ts-btn-outline">Huỷ</a>
        </div>
    </form>
</div>