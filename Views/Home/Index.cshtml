@{
    ViewData["Title"] = "Home Page";
}
@if (TempData["Success"] != null)
{
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;
                padding:12px 16px;background:#EAFAF0;border-radius:8px;
                border:1px solid #A8DFC0">
        <i class="fa-solid fa-circle-check" style="color:#1A8C4E;font-size:15px"></i>
        <span style="font-size:12.5px;color:#1A6E3E;font-weight:500">@TempData["Success"]</span>
    </div>
}

@if (TempData["Danger"] != null)
{
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;
                padding:12px 16px;background:#FEE9E9;border-radius:8px;
                border:1px solid #F0B8B8">
        <i class="fa-solid fa-circle-xmark" style="color:#A83232;font-size:15px"></i>
        <span style="font-size:12.5px;color:#A83232;font-weight:500">@TempData["Danger"]</span>
    </div>
}
<div class="text-center">
   
</div>
